{
  "expo": {
    "name": "CivicFixApp",
    "slug": "CivicFixApp",
    "version": "1.0.0",
    "scheme": "com.civicfix.app",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CivicFix to access your location to tag civic issues."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CivicFix to access your photos to attach issue proof."
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "106573a1-d435-4c86-9ae8-df9c31deca35"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khcoder.CivicFixApp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.khcoder.CivicFixApp",
      "config": {
        "googleMaps": {
          "apiKey": "$GMAP_API_KEY"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    }
  }
}
